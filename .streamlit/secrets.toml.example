# ── TUMA206 dashboard secrets ─────────────────────────────────────────
# HOW TO USE
#   * Streamlit Cloud:  Manage app -> Settings -> Secrets, paste the lines below
#                       (without this comment block). NEVER commit the real key.
#   * Local:            copy this file to  .streamlit/secrets.toml  and fill in.
#
# SECURITY: the API key is a password. Do not paste it into chat, screenshots, or
# git. If it has been shared, rotate (regenerate) it.

# ── M5 AI assistant ────────────────────────────────────────────────────
# Provide ONE key. The provider is auto-detected from the prefix:
#   sk-proj-… / sk-…  -> OpenAI      |   sk-ant-…  -> Anthropic Claude
OPENAI_API_KEY = "sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx"
# ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"
# OPENAI_MODEL = "gpt-4o-mini"     # optional, this is the default

# ── Dashboard mode ─────────────────────────────────────────────────────
# "local"  (default) = self-contained, runs the whole simulation in-process.
# "remote"           = DISPLAY-ONLY: no simulation here; read tags from MQTT and
#                      send commands over MQTT (route B — cloud dashboard only).
# DASHBOARD_MODE = "remote"

# ── MQTT broker (only needed for DASHBOARD_MODE = "remote", route B) ────
# Default broker is the public HiveMQ test broker (no auth, no setup). For a
# reliable demo use a private broker (HiveMQ Cloud) and fill in auth + TLS.
# MQTT_HOST = "broker.hivemq.com"
# MQTT_PORT = "1883"
# MQTT_TOPIC_PREFIX = "tuma206grp1bvg"   # MUST match the local backend
# MQTT_USERNAME = ""
# MQTT_PASSWORD = ""
# MQTT_TLS = "0"     # set to "1" for a TLS broker (then MQTT_PORT is usually 8883)

# ── Telegram alarm notifications (optional) ────────────────────────────
# Used by the LOCAL BACKEND (not the cloud dashboard). Token from @BotFather,
# chat id from getUpdates. See README "Telegram alarms".
# TELEGRAM_BOT_TOKEN = "123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TELEGRAM_CHAT_ID = "-1001234567890"
