# Local config for running the LOCAL BACKEND (local_backend.py) and a local
# dashboard. Copy this file to ".env" and fill in. config.py auto-loads ".env".
# .env is gitignored — never commit real keys/credentials.

# ── M5 AI assistant (one key; provider auto-detected from prefix) ──────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── MQTT broker (route B) ─────────────────────────────────────────────
# Default (no setup): public HiveMQ test broker, no auth, port 1883.
# Private HiveMQ Cloud (recommended for the demo): fill all of these.
# MQTT_HOST=xxxxxxxxxxxx.s1.eu.hivemq.cloud
# MQTT_PORT=8883
# MQTT_TLS=1
# MQTT_USERNAME=your_broker_username
# MQTT_PASSWORD=your_broker_password
# MQTT_TOPIC_PREFIX=tuma206grp1bvg

# ── Telegram alarm notifications (optional) ───────────────────────────
# When set, the local backend pushes a message to your Telegram group on
# every alarm. Token from @BotFather; chat id from getUpdates (see README).
# TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=-1001234567890
